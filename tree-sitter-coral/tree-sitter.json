{
  "grammars": [
    {
      "name": "coral",
      "camelcase": "Coral",
      "scope": "source.coral",
      "path": ".",
      "file-types": [
        "coral"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^coral$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Coral programming language",
    "authors": [
      {
        "name": "Coral Contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-coral"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
