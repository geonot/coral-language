#!/usr/bin/env bash
#
# coral-dev.env — Source this file to get coral-dev as shell functions.
#
#   source tools/coral-dev.env
#
# Then use:
#   ct summary          # run tests (summary)
#   ct failures         # show only failures
#   ct one my_test      # single test
#   cr examples/hello.coral  # compile + run
#   cb                  # build all
#   cm                  # codemap compact
#   cf sym compile      # find symbol
#   cs                  # project status
#   co                  # onboard quick
#

_CORAL_DEV="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)/coral-dev"

# Core aliases — these are the most frequently used
ct() { "$_CORAL_DEV" test "$@"; }       # ct = coral test
cr() { "$_CORAL_DEV" run "$@"; }        # cr = coral run
cb() { "$_CORAL_DEV" build "$@"; }      # cb = coral build
cc() { "$_CORAL_DEV" compile "$@"; }    # cc = coral compile
cm() { "$_CORAL_DEV" codemap "$@"; }    # cm = coral map
cf() { "$_CORAL_DEV" find "$@"; }       # cf = coral find
cs() { "$_CORAL_DEV" status "$@"; }     # cs = coral status
co() { "$_CORAL_DEV" onboard "$@"; }    # co = coral onboard
cx() { "$_CORAL_DEV" xref "$@"; }       # cx = coral xref
ce() { "$_CORAL_DEV" errors "$@"; }     # ce = coral errors
cd_() { "$_CORAL_DEV" diff "$@"; }      # cd_ = coral diff (cd is taken)

# Navigation helpers (powered by codemap.py)
cg() { "$_CORAL_DEV" goto "$@"; }       # cg = coral goto
cx_() { "$_CORAL_DEV" extract "$@"; }    # cx_ = coral extract
cctx() { "$_CORAL_DEV" context "$@"; }   # cctx = coral context
csym() { "$_CORAL_DEV" symbols "$@"; }   # csym = coral symbols
ccl() { "$_CORAL_DEV" checklist "$@"; }  # ccl = coral checklist
csc() { "$_CORAL_DEV" scaffold "$@"; }   # csc = coral scaffold
cpe() { "$_CORAL_DEV" parse-errors "$@"; } # cpe = coral parse-errors

echo "coral-dev functions loaded: ct cr cb cc cm cf cs co cx ce cd_ cg cx_ cctx csym ccl csc cpe"
echo "Type 'ct failures' to run tests, 'co' to onboard, 'cg <file> <sym>' to find symbols"
