# Test: many functions to stress the compiler
*add(a, b)
	return a + b

*sub(a, b)
	return a - b

*mul(a, b)
	return a * b

*is_even(n)
	return n % 2 is 0

*abs_val(x)
	if x < 0
		return 0 - x
	return x

*max_val(a, b)
	if a > b
		return a
	return b

*min_val(a, b)
	if a < b
		return a
	return b

*fib(n)
	if n < 2
		return n
	a is 0
	b is 1
	i is 2
	while i <= n
		c is a + b
		a is b
		b is c
		i is i + 1
	return b

*factorial(n)
	result is 1
	i is 1
	while i <= n
		result is result * i
		i is i + 1
	return result

*make_pair(x, y)
	return map("first" is x, "second" is y)

*sum_list(lst)
	total is 0
	for item in lst
		total is total + item
	return total

*filter_positive(lst)
	result is []
	for item in lst
		if item > 0
			result.push(item)
	return result

*main()
	log(add(10, 20))
	log(sub(50, 25))
	log(fib(10))
	log(factorial(5))
	pair is make_pair(1, 2)
	log(pair.get("first"))
	nums is [1, 2, 3, 4, 5]
	log(sum_list(nums))
	pos is filter_positive([-1, 2, -3, 4, 5])
	log(pos.length())
